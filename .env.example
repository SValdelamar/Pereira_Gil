# =============================================================================
# Archivo de Configuración de Ejemplo - Sistema de Laboratorios SENA
# =============================================================================
# 
# Instrucciones:
# 1. Copiar este archivo como .env_produccion
# 2. Modificar los valores según tu entorno
# 3. NO subir .env_produccion al repositorio (contiene credenciales)
# 
# Buenas Prácticas:
# - Usar contraseñas seguras (mínimo 12 caracteres)
# - No usar usuarios root para producción
# - Configurar IP específica si es posible
# - Usar SSL/TLS en producción
# =============================================================================

# =============================================================================
# CONFIGURACIÓN DE BASE DE DATOS
# =============================================================================

# Host de la base de datos (localhost para desarrollo, IP para producción)
DB_HOST=localhost

# Usuario de la base de datos (evitar root en producción)
DB_USER=root

# Contraseña de la base de datos (mínimo 12 caracteres, símbolos incluidos)
DB_PASSWORD=1234

# Nombre de la base de datos
DB_NAME=laboratorio_sistema

# Puerto de MySQL (dejar comentado para usar puerto por defecto 3306)
# DB_PORT=3306

# =============================================================================
# CONFIGURACIÓN DE LA APLICACIÓN
# =============================================================================

# Entorno de ejecución (development, production, testing)
FLASK_ENV=development

# Modo debug (solo para desarrollo, NUNCA en producción)
FLASK_DEBUG=True

# Clave secreta para sesiones (cambiar en producción)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=tu_clave_secreta_aqui_cambiar_en_produccion

# URL base de la aplicación
APP_URL=http://localhost:5000

# =============================================================================
# CONFIGURACIÓN DE SEGURIDAD
# =============================================================================

# Tiempo de sesión en minutos
SESSION_TIMEOUT=30

# Máximo de intentos fallidos de login
MAX_LOGIN_ATTEMPTS=3

# Tiempo de bloqueo por intentos fallidos (minutos)
LOGIN_LOCKOUT_TIME=15

# Requerir HTTPS en producción (True/False)
FORCE_HTTPS=False

# =============================================================================
# CONFIGURACIÓN DE CORREO ELECTRÓNICO
# =============================================================================

# Servidor SMTP para notificaciones
SMTP_SERVER=smtp.gmail.com

# Puerto SMTP (587 para TLS, 465 para SSL)
SMTP_PORT=587

# Usuario del correo electrónico
SMTP_EMAIL=tu_correo@sena.edu.co

# Contraseña del correo electrónico (usar app password para Gmail)
SMTP_PASSWORD=tu_contraseña_de_correo

# Nombre del remitente
EMAIL_FROM=Sistema Laboratorios SENA <tu_correo@sena.edu.co>

# Usar TLS/SSL (True/False)
SMTP_USE_TLS=True

# =============================================================================
# CONFIGURACIÓN DE BACKUP
# =============================================================================

# Directorio para backups (relativo a la raíz del proyecto)
BACKUP_DIR=backups

# Retención de backups en días
BACKUP_RETENTION_DAYS=30

# Backup automático (True/False)
BACKUP_AUTOMATIC=True

# Hora del backup automático (formato 24h)
BACKUP_TIME=02:00

# =============================================================================
# CONFIGURACIÓN DE IA Y RECONOCIMIENTO
# =============================================================================

# Ruta al modelo de reconocimiento facial
FACE_RECOGNITION_MODEL=models/face_recognition.pkl

# Umbral de similitud para reconocimiento facial (0.0-1.0)
FACE_RECOGNITION_THRESHOLD=0.70

# Ruta al modelo de visión artificial
VISION_MODEL=models/vision_model.pkl

# Umbral de confianza para IA visual (0.0-1.0)
VISION_CONFIDENCE_THRESHOLD=0.75

# =============================================================================
# CONFIGURACIÓN DE LOGGING
# =============================================================================

# Nivel de logging (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Directorio para logs
LOG_DIR=logs

# Rotación de logs (True/False)
LOG_ROTATION=True

# Máximo tamaño de archivo de log (MB)
LOG_MAX_SIZE=10

# Cantidad máxima de archivos de log
LOG_MAX_FILES=5

# =============================================================================
# CONFIGURACIÓN DE ARCHIVOS
# =============================================================================

# Directorio para imágenes subidas
UPLOAD_DIR=imagenes

# Tamaño máximo de archivo (MB)
MAX_FILE_SIZE=10

# Tipos de archivo permitidos (separados por coma)
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,pdf,doc,docx,xls,xlsx

# =============================================================================
# CONFIGURACIÓN DE API
# =============================================================================

# Límite de rate limiting (solicitudes por minuto)
API_RATE_LIMIT=100

# Tiempo de expiración de tokens JWT (minutos)
JWT_EXPIRATION=60

# =============================================================================
# CONFIGURACIÓN DE INTEGRACIONES
# =============================================================================

# URL de webhook para notificaciones (opcional)
WEBHOOK_URL=

# Clave de API para servicios externos (opcional)
EXTERNAL_API_KEY=

# =============================================================================
# CONFIGURACIÓN DE MONITOREO
# =============================================================================

# Habilitar monitoreo de rendimiento (True/False)
ENABLE_MONITORING=False

# URL del servicio de monitoreo (opcional)
MONITORING_URL=

# =============================================================================
# VARIABLES DE ENTORNO ESPECÍFICAS
# =============================================================================

# Para desarrollo
# FLASK_ENV=development
# FLASK_DEBUG=True
# DB_HOST=localhost

# Para producción
# FLASK_ENV=production
# FLASK_DEBUG=False
# DB_HOST=tu_ip_servidor
# FORCE_HTTPS=True

# Para testing
# FLASK_ENV=testing
# DB_NAME=laboratorio_test
# LOG_LEVEL=DEBUG

# =============================================================================
# NOTAS IMPORTANTES
# =============================================================================

# 1. CAMBIAR CONTRASEÑAS: Nunca usar las contraseñas por defecto en producción
# 2. CLAVES SECRETAS: Generar claves únicas para cada instalación
# 3. PERMISOS: Asegurar que los archivos .env no sean accesibles vía web
# 4. BACKUPS: Configurar backups automáticos y probar restauración
# 5. ACTUALIZACIONES: Mantener el sistema y dependencias actualizadas
# 6. MONITOREO: Configurar alertas para errores y actividad sospechosa

# =============================================================================
# COMANDOS ÚTILES
# =============================================================================

# Generar clave secreta:
# python -c "import secrets; print(secrets.token_hex(32))"

# Probar conexión a BD:
# mysql -h localhost -u laboratorio_prod -p laboratorio_sistema

# Ejecutar migraciones:
# python migrate.py

# Verificar instalación:
# python check_server.py

# =============================================================================
# NOTIFICACIONES Y ALERTAS DE MANTENIMIENTO PREDICTIVO
# =============================================================================

# Habilitar canales de notificación
HABILITAR_EMAIL=false
HABILITAR_DASHBOARD=true
HABILITAR_SMS=false
HABILITAR_WEBHOOK=false

# Configuración de Email
EMAIL_SERVIDOR=smtp.gmail.com
EMAIL_PUERTO=587
EMAIL_USUARIO=tu_email@gmail.com
EMAIL_PASSWORD=tu_contraseña_de_aplicacion
EMAIL_REMITENTE=sistema@sena.edu.co
EMAIL_NOMBRE_REMITENTE=Sistema de Laboratorios SENA
EMAIL_USAR_TLS=true
EMAIL_USAR_SSL=false
EMAIL_MAX_POR_HORA=100
EMAIL_MAX_DESTINATARIOS=50

# Configuración de Mantenimiento Predictivo
DIAS_ANTICIPACION_MANTENIMIENTO=30
DIAS_ANTICIPACION_CALIBRACION=15
DIAS_ANTICIPACION_CRITICO=7
UMBRAL_RIESGO_ALTO=0.7
UMBRAL_RIESGO_MEDIO=0.4
UMBRAL_USO_EXCESIVO=20
FRECUENCIA_REVISION=24
DIAS_HISTORIAL=365
MIN_MANTENIMIENTOS_PREDICCION=3
FACTOR_CALIBRACION=1.2
FACTOR_USO_INTENSIVO=1.5
FACTOR_EQUIPO_ANTIGUO=1.3

# Configuración de Dashboard
DASHBOARD_CRITICAS_PRIMERO=true
DASHBOARD_MAX_ALERTAS=50
DASHBOARD_AUTO_ACTUALIZAR=300
DASHBOARD_SOLO_NO_LEIDAS=false
DASHBOARD_AGRUPAR_TIPO=true

# Configuración de SMS (opcional)
SMS_PROVEEDOR=twilio
SMS_API_KEY=tu_api_key
SMS_API_SECRET=tu_api_secret
SMS_REMITENTE=+1234567890
SMS_MAX_POR_DIA=100
SMS_SOLO_CRITICAS=true

# Configuración de Webhook (opcional)
WEBHOOK_URLS=https://webhook.ejemplo.com/alertas
WEBHOOK_HEADERS={"Authorization": "Bearer token"}
WEBHOOK_TIMEOUT=30
WEBHOOK_REINTENTOS=3
WEBHOOK_SOLO_CRITICAS=false

# Configuración General de Notificaciones
ENVIAR_SOLO_LABORAL=false
HORARIO_LABORAL_INICIO=08:00
HORARIO_LABORAL_FIN=18:00
DIAS_LABORALES=lunes,martes,miércoles,jueves,viernes
ADMINISTRADORES=admin@sena.edu.co,coordinador@sena.edu.co
INSTRUCTORES=instructor1@sena.edu.co,instructor2@sena.edu.co
